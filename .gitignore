# Dart / Flutter build + tool output (regenerated; never commit or publish).
.dart_tool/
build/
.flutter-plugins
.flutter-plugins-dependencies
.packages

# A library package publishes no lockfile (apps pin, libraries don't).
pubspec.lock

# IDE / editor / OS noise.
.idea/
.vscode/
*.iml
*.log
.DS_Store

# The example ships source only — its platform runner projects and local perf
# scaffolding are regenerated by `flutter create .` and stay out of the repo.
example/android/
example/ios/
example/linux/
example/macos/
example/windows/
example/web/
example/integration_test/
example/test_driver/
